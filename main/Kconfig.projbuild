menu "Photo Frame Configuration"

    choice EPDIY_DISPLAY
        prompt "E-paper display model"
        default EPDIY_DISPLAY_ES108FC2
        help
            Select the e-paper panel connected to the epdiy board.
            The choice maps to an EpdDisplay_t definition in epdiy_main.c
            (resolution, bus width/speed and default waveform).

        config EPDIY_DISPLAY_ES108FC2
            bool "ES108FC2 — 1920x1080, 16-bit (project default)"

        config EPDIY_DISPLAY_ES108FC
            bool "ES108FC — 1920x1080"

        config EPDIY_DISPLAY_ES080FC
            bool "ES080FC — 1800x600, 16-bit"

        config EPDIY_DISPLAY_ES120
            bool "ES120 — 2560x1600, 16-bit"

        config EPDIY_DISPLAY_ED060KD1
            bool "ED060KD1 — 1448x1072, 8-bit"

        config EPDIY_DISPLAY_EC080SC2
            bool "EC080SC2 — 1800x800, 16-bit"
    endchoice

endmenu
