# ESP32-S3 specific defaults.

# --- Flash: 16 MB ---
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# --- Custom partition table: large factory app + photo storage ---
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/esp32s3_n16r8.csv"

# --- Octal PSRAM (e.g. N16R8 = 8 MB), required for the epdiy framebuffer ---
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# --- Data cache: 64 KB with a 64-byte line — required by epdiy's parallel LCD
#     DMA. A 32-byte line makes epdiy drop the pixel clock and causes
#     "line buffer underrun" / "draw error: 400" (screen never refreshes). ---
CONFIG_ESP32S3_DATA_CACHE_64KB=y
CONFIG_ESP32S3_DATA_CACHE_LINE_64B=y
